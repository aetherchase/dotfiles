#!/bin/bash
# Regenerate ~/.config/hypr/theme-border.conf with a neutral hairline border
# (theme foreground @ ~12%) to match the Walker launcher card style.
# Called by omarchy after every theme switch with the theme name as $1.
THEME_NAME="$1"
THEME_SLUG=$(echo "$THEME_NAME" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

# Prefer user-overridden theme, fall back to stock
if [ -d "$HOME/.config/omarchy/themes/$THEME_SLUG" ]; then
    THEME_DIR="$HOME/.config/omarchy/themes/$THEME_SLUG"
elif [ -d "$HOME/.local/share/omarchy/themes/$THEME_SLUG" ]; then
    THEME_DIR="$HOME/.local/share/omarchy/themes/$THEME_SLUG"
else
    exit 0
fi

COLORS="$THEME_DIR/colors.toml"
[ -f "$COLORS" ] || exit 0

# Extract foreground hex (strip # and quotes) for a neutral hairline border
fg=$(grep '^foreground' "$COLORS" | sed 's/.*"#\([^"]*\)".*/\1/')

[ -z "$fg" ] && exit 0

cat > "$HOME/.config/hypr/theme-border.conf" <<EOF
# Auto-generated by ~/.config/omarchy/hooks/theme-set — do not edit manually.
# Neutral hairline (theme foreground @ ~12%), matching the Walker launcher card.
# Active + inactive identical; focus is shown via dim_inactive (looknfeel.conf).
general {
    col.active_border = rgba(${fg}1f)
    col.inactive_border = rgba(${fg}1f)
}
EOF

hyprctl reload
