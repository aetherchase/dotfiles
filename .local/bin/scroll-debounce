#!/usr/bin/env python3
"""scroll-debounce — filter phantom opposite-direction scroll ticks.

A worn rotary encoder (here: cat fur in the wheel) makes one quadrature channel
misfire, so the kernel emits a spurious reversed REL_WHEEL tick in the middle of
a scroll burst. This grabs the physical mouse, drops any vertical-wheel event
whose direction is opposite to the current scroll within DEBOUNCE_WINDOW, and
re-emits a clean stream through a virtual uinput device.

The virtual device gets a DISTINCT name (Hyprland dedups duplicate names with a
"-1" suffix, so reusing the original's name does not work). input-devices.conf
carries a matching device rule so accel_profile / sensitivity apply to this
virtual device.

Env config:
  SD_DEVICE_NAME   exact device name to filter (default below)
  SD_VIRTUAL_NAME  name of the re-emitted virtual device (default below)
  SD_WINDOW_MS     debounce window in ms (default 50)
  SD_DEBUG         "1" to log dropped/passed reversals to the journal

Failsafe: if this process dies, the grab is released and the real mouse works
normally again.
"""
import os
import sys
import time

import evdev
from evdev import ecodes, InputDevice, UInput

DEVICE_NAME = os.environ.get("SD_DEVICE_NAME", "Compx 2.4G Wireless Receiver")
VIRTUAL_NAME = os.environ.get("SD_VIRTUAL_NAME", "Compx 2.4G Debounced")
WINDOW = float(os.environ.get("SD_WINDOW_MS", "50")) / 1000.0
DEBUG = os.environ.get("SD_DEBUG", "") == "1"

# Vertical-wheel codes we debounce. Horizontal wheel is passed through untouched.
WHEEL_CODES = (ecodes.REL_WHEEL, ecodes.REL_WHEEL_HI_RES)


def log(*a):
    print(*a, file=sys.stderr, flush=True)


def find_device():
    """Return the InputDevice named DEVICE_NAME that has a vertical wheel."""
    for path in evdev.list_devices():
        try:
            d = InputDevice(path)
        except OSError:
            continue
        rel = d.capabilities().get(ecodes.EV_REL, [])
        if d.name == DEVICE_NAME and (
            ecodes.REL_WHEEL in rel or ecodes.REL_WHEEL_HI_RES in rel
        ):
            return d
        d.close()
    return None


def frame_direction(frame):
    """Sign (+1/-1/0) of the frame's vertical wheel; prefer hi-res."""
    for code in (ecodes.REL_WHEEL_HI_RES, ecodes.REL_WHEEL):
        for e in frame:
            if e.type == ecodes.EV_REL and e.code == code and e.value != 0:
                return 1 if e.value > 0 else -1
    return 0


def run(dev):
    # from_device merges capabilities. A distinct name avoids Hyprland's "-1"
    # dedup suffix; input-devices.conf has a matching rule for VIRTUAL_NAME.
    ui = UInput.from_device(dev, name=VIRTUAL_NAME)
    dev.grab()
    log(f"grabbed {dev.path} ({dev.name}); virtual={ui.device.path}; "
        f"window={WINDOW * 1000:.0f}ms debug={DEBUG}")

    last_dir = 0      # last accepted vertical direction (+1/-1)
    last_time = 0.0   # timestamp of last accepted same-direction event
    frame = []        # events buffered for the current SYN_REPORT frame

    try:
        for ev in dev.read_loop():
            if not (ev.type == ecodes.EV_SYN and ev.code == ecodes.SYN_REPORT):
                frame.append(ev)
                continue

            t = ev.sec + ev.usec / 1e6
            direction = frame_direction(frame)
            drop = False

            if direction != 0:
                if last_dir == 0 or direction == last_dir:
                    last_dir, last_time = direction, t          # extend the burst
                elif t - last_time < WINDOW:
                    drop = True                                 # phantom reversal
                    if DEBUG:
                        log(f"DROP dir={direction:+d} gap={(t - last_time) * 1000:.1f}ms")
                else:
                    last_dir, last_time = direction, t          # genuine reversal
                    if DEBUG:
                        log(f"KEEP reversal dir={direction:+d} gap={(t - last_time) * 1000:.1f}ms")

            for e in frame:
                if drop and e.type == ecodes.EV_REL and e.code in WHEEL_CODES:
                    continue
                ui.write_event(e)
            ui.syn()
            frame = []
    finally:
        try:
            dev.ungrab()
        except OSError:
            pass
        ui.close()


def main():
    log(f"scroll-debounce starting; target='{DEVICE_NAME}'")
    while True:
        dev = find_device()
        if dev is None:
            time.sleep(2)                  # wait for the dongle / device to appear
            continue
        try:
            run(dev)
        except OSError as e:
            log(f"device error ({e}); rescanning")
            try:
                dev.close()
            except OSError:
                pass
            time.sleep(2)


if __name__ == "__main__":
    main()
