# Let processes in the `input` group create virtual input devices via uinput.
# Required by the scroll-debounce user service (no root daemon needed).
# Security note: input-group users can already read input devices; this also
# lets them synthesize input events (keystrokes/clicks). Acceptable on a
# single-user desktop. Install: see system/install-scroll-debounce.sh
KERNEL=="uinput", SUBSYSTEM=="misc", GROUP="input", MODE="0660", OPTIONS+="static_node=uinput"
