*.bak
*.bak.*
*.new

# per-host feature selection (override of features.conf)
features.local

# yazi plugins managed by `ya pkg` — restore from package.toml
features/yazi/.config/yazi/plugins/

# yazi runtime state
features/yazi/.config/yazi/*.db
features/yazi/.config/yazi/*.db-*

# wallpaper symlinks: machine-specific, point to a personal collection —
# regenerate with ./link-omarchy-wallpapers.sh (apply.sh runs it for `wallpapers`)
features/wallpapers/.config/omarchy/backgrounds/*
!features/wallpapers/.config/omarchy/backgrounds/.gitkeep

# editor/OS junk
*.swp
*~
.DS_Store
__pycache__/
*.pyc
